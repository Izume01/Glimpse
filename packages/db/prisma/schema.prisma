generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id           BigInt   @id @default(autoincrement())

  projectId    String
  name         String
  occurredAt   DateTime
  receivedAt   DateTime @default(now())

  anonymousId  String
  userId       String?
  sessionId    String

  traits       Json?
  properties   Json?
  context      Json?

  ip           String?
  userAgent    String?

  country      String?
  region       String?
  city         String?
  timezone     String?
  lat          Float?
  lon          Float?

  @@map("events")
  @@index([projectId, occurredAt])
  @@index([projectId, sessionId])
  @@index([projectId, anonymousId])
  @@index([projectId, userId])
}

model AnalyticsSession {
  projectId    String
  sessionId    String

  anonymousId  String
  userId       String?

  startedAt    DateTime
  lastSeenAt   DateTime
  eventCount   Int

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("analytics_sessions")
  @@id([projectId, sessionId])
  @@index([projectId, startedAt])
  @@index([projectId, anonymousId])
}


model HourlyEventAggregate {
  projectId String
  timestamp DateTime
  eventName String

  count     Int
  users     Int
  sessions  Int

  @@map("hourly_event_aggregates")
  @@id([projectId, timestamp, eventName])
}



model HourlyPageAnalytics {
  projectId String
  timestamp DateTime
  pagePath  String

  views        Int
  uniqueUsers  Int
  sessions     Int
  bounces      Int
  entrances    Int @default(0)
  exits        Int @default(0)
  duration     Float @default(0)

  @@map("hourly_page_analytics")
  @@id([projectId, timestamp, pagePath])
}

model HourlyReferrerAnalytics {
  projectId   String
  timestamp   DateTime
  referrer    String

  views       Int
  uniqueUsers Int
  sessions    Int

  @@map("hourly_referrer_analytics")
  @@id([projectId, timestamp, referrer])
}

model HourlyDeviceAnalytics {
  projectId   String
  timestamp   DateTime
  deviceType  String
  browser     String
  os          String

  uniqueUsers Int
  sessions    Int

  @@map("hourly_device_analytics")
  @@id([projectId, timestamp, deviceType, browser, os])
}

model HourlyCountryAnalytics {
  projectId   String
  timestamp   DateTime
  country     String
  region      String
  city        String

  uniqueUsers Int
  sessions    Int

  @@map("hourly_country_analytics")
  @@id([projectId, timestamp, country, region, city])
}

model HourlyCampaignAnalytics {
  projectId   String
  timestamp   DateTime
  utmSource   String
  utmMedium   String
  utmCampaign String
  utmTerm     String
  utmContent  String

  views       Int
  uniqueUsers Int
  sessions    Int

  @@map("hourly_campaign_analytics")
  @@id([projectId, timestamp, utmSource, utmMedium, utmCampaign, utmTerm, utmContent])
}

model HourlySiteMetrics {
  projectId     String
  timestamp     DateTime

  visitors      Int
  views         Int
  sessions      Int
  bounces       Int
  totalDuration Float

  @@map("hourly_site_metrics")
  @@id([projectId, timestamp])
}


model HourlyUserAnalytics {
  projectId   String
  timestamp   DateTime
  anonymousId String

  sessions    Int
  isNew       Boolean

  @@map("hourly_user_analytics")
  @@id([projectId, timestamp, anonymousId])
}



model AnalyticsCheckpoint {
  name        String  @id
  lastEventId BigInt
  updatedAt   DateTime @updatedAt
}
